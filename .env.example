# LLM Providers (Only one is strictly required)
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Application Config
APP_ENV=development
LLM_PROVIDER=openai  # Options: openai, gemini
MODEL_NAME=gpt-4o    # e.g., gpt-4o for OpenAI, gemini-1.5-pro for Gemini

# RAG & Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
FAISS_INDEX_PATH=data/index/catalog.faiss
CATALOG_METADATA_PATH=data/index/metadata.json

# Web Scraping 
SHL_CATALOG_URL=https://www.shl.com/solutions/products/product-catalog/
